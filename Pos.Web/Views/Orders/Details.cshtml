@model Pos.Web.Models.OrderViewModel
@{ ViewData["Title"] = "Sipariş Detayı"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-receipt me-2"></i>Sipariş #@Model.Id.ToString()[..8]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Geri
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="row g-3">
    <div class="col-md-4">
        <div class="card shadow-sm mb-3">
            <div class="card-header fw-semibold"><i class="bi bi-info-circle me-1"></i>Sipariş Bilgileri</div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-muted">Müşteri</span><strong>@Model.CustomerName</strong>
                </li>
                @if (Model.TableNumber.HasValue)
                {
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Masa</span><strong>Masa @Model.TableNumber</strong>
                    </li>
                }
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-muted">Durum</span>
                    <span class="badge bg-@Model.StatusBadge">@Model.StatusName</span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-muted">Toplam</span>
                    <strong class="text-success">@Model.TotalAmount.ToString("N2") ₺</strong>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-muted">Tarih</span>
                    <span>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                </li>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <li class="list-group-item"><span class="text-muted">Not: </span>@Model.Notes</li>
                }
            </ul>
        </div>
        @if (Model.Status < 4)
        {
            <div class="card shadow-sm">
                <div class="card-header fw-semibold"><i class="bi bi-arrow-repeat me-1"></i>Durum Güncelle</div>
                <div class="card-body d-grid gap-2">
                    @if (Model.Status < 1)
                    {
                        <form asp-action="UpdateStatus" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="status" value="1" />
                            <button class="btn btn-warning w-100"><i class="bi bi-fire me-1"></i>Mutfağa İlet</button>
                        </form>
                    }
                    @if (Model.Status == 1)
                    {
                        <form asp-action="UpdateStatus" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="status" value="2" />
                            <button class="btn btn-info w-100"><i class="bi bi-bell me-1"></i>Hazır İşaretle</button>
                        </form>
                    }
                    @if (Model.Status == 2)
                    {
                        <form asp-action="UpdateStatus" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="status" value="3" />
                            <button class="btn btn-primary w-100"><i class="bi bi-bag-check me-1"></i>Servis Edildi</button>
                        </form>
                    }
                    @if (Model.Status >= 3)
                    {
                        <a asp-controller="Payments" asp-action="Process" asp-route-orderId="@Model.Id"
                           class="btn btn-success w-100">
                            <i class="bi bi-credit-card me-1"></i>Ödeme Al
                        </a>
                    }
                    <form asp-action="Cancel" asp-route-id="@Model.Id" method="post">
                        <button class="btn btn-outline-danger w-100"
                                onclick="return confirm('Siparişi iptal etmek istediğinize emin misiniz?')">
                            <i class="bi bi-x-circle me-1"></i>İptal Et
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold"><i class="bi bi-list-ul me-1"></i>Sipariş Kalemleri</div>
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead class="table-light">
                        <tr><th>Ürün</th><th class="text-center">Adet</th><th class="text-end">Birim</th><th class="text-end">Toplam</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td class="text-center"><span class="badge bg-secondary">@item.Quantity</span></td>
                                <td class="text-end">@item.UnitPrice.ToString("N2") ₺</td>
                                <td class="text-end fw-bold">@item.TotalPrice.ToString("N2") ₺</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-dark">
                            <td colspan="3" class="text-end fw-bold">TOPLAM</td>
                            <td class="text-end fw-bold">@Model.TotalAmount.ToString("N2") ₺</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header"><strong>Sipariş Bilgileri</strong></div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item"><strong>Müşteri:</strong> @Model.CustomerName</li>
                <li class="list-group-item">
                    <strong>Durum:</strong>
                    @{
                        var cls = Model.Status switch { 0 => "bg-secondary", 1 => "bg-warning text-dark", 2 => "bg-success", 3 => "bg-danger", _ => "bg-light" };
                    }
                    <span class="badge @cls">@Model.StatusName</span>
                </li>
                <li class="list-group-item"><strong>Toplam:</strong> <span class="fs-5 text-success fw-bold">@Model.TotalAmount.ToString("C2")</span></li>
                <li class="list-group-item"><strong>Tarih:</strong> @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</li>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <li class="list-group-item"><strong>Not:</strong> @Model.Notes</li>
                }
            </ul>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header"><strong>Sipariş Kalemleri</strong></div>
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead><tr><th>Ürün</th><th>Miktar</th><th>Birim Fiyat</th><th>Toplam</th></tr></thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td>@item.Quantity</td>
                                <td>@item.UnitPrice.ToString("C2")</td>
                                <td><strong>@item.TotalPrice.ToString("C2")</strong></td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-dark">
                            <td colspan="3" class="text-end"><strong>TOPLAM</strong></td>
                            <td><strong>@Model.TotalAmount.ToString("C2")</strong></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

