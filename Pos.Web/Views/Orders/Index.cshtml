@model List<Pos.Web.Models.OrderViewModel>
@{ ViewData["Title"] = "Siparişler"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-cart me-2"></i>Sipariş Listesi</h2>
    <a asp-action="Create" class="btn btn-warning text-dark"><i class="bi bi-plus-circle me-1"></i>Yeni Sipariş</a>
</div>

@if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>Müşteri</th><th>Tutar</th><th>Durum</th><th>Tarih</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var o in Model)
            {
                <tr>
                    <td>@o.CustomerName</td>
                    <td><strong>@o.TotalAmount.ToString("C2")</strong></td>
                    <td>
                        @{
                            var badgeClass = o.Status switch { 0 => "bg-secondary", 1 => "bg-warning text-dark", 2 => "bg-success", 3 => "bg-danger", _ => "bg-light" };
                        }
                        <span class="badge @badgeClass">@o.StatusName</span>
                    </td>
                    <td>@o.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@o.Id" class="btn btn-sm btn-outline-warning">Detay</a>
                        @if (o.Status == 0 || o.Status == 1)
                        {
                            <a asp-controller="Payments" asp-action="Process" asp-route-orderId="@o.Id" class="btn btn-sm btn-success ms-1">Ödeme Al</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

