@{
    ViewData["Title"] = "Erişim Engellendi";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow border-danger">
                <div class="card-body py-5">
                    <i class="bi bi-shield-lock-fill text-danger" style="font-size: 4rem;"></i>
                    <h2 class="mt-3 text-danger">Erişim Engellendi</h2>
                    <p class="text-muted mt-3">Bu sayfayı görüntülemek için yeterli yetkiniz bulunmamaktadır.</p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
                        <i class="bi bi-house-fill me-1"></i> Ana Sayfaya Dön
                    </a>
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-secondary mt-3 ms-2">
                        <i class="bi bi-box-arrow-right me-1"></i> Çıkış Yap
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
