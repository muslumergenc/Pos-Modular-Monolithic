@model Pos.Web.Models.PaymentViewModel
@{ ViewData["Title"] = "Ödeme Detayı"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-receipt me-2"></i>Ödeme Detayı</h2>
    <a asp-action="Index" class="btn btn-secondary">Listeye Dön</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="row justify-content-center">
    <div class="col-md-6">
        @{
            var statusCls = Model.Status switch
            {
                1 => "border-success",
                2 => "border-danger",
                3 => "border-warning",
                _ => "border-secondary"
            };
            var statusLabel = Model.Status switch
            {
                1 => "✅ Ödeme Tamamlandı",
                2 => "❌ Ödeme Başarısız",
                3 => "↩️ İade Edildi",
                _ => "⏳ Bekliyor"
            };
        }
        <div class="card @statusCls border-3 shadow">
            <div class="card-header text-center fs-5 fw-bold">@statusLabel</div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between">
                    <strong>Tutar</strong>
                    <span class="fs-5 fw-bold text-success">@Model.Amount.ToString("C2")</span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <strong>Yöntem</strong><span>@Model.MethodName</span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <strong>Referans</strong><code>@(Model.TransactionReference ?? "-")</code>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <strong>İşlem Tarihi</strong>
                    <span>@(Model.ProcessedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <strong>Sipariş</strong>
                    <a asp-controller="Orders" asp-action="Details" asp-route-id="@Model.OrderId">
                        #@Model.OrderId.ToString()[..8]...
                    </a>
                </li>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <li class="list-group-item"><strong>Not:</strong> @Model.Notes</li>
                }
            </ul>
            @if (Model.Status == 1)
            {
                <div class="card-footer text-center">
                    <form asp-action="Refund" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-outline-warning"
                                onclick="return confirm('İade işlemi başlatılsın mı?')">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>İade Et
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>

