@model Pos.Web.Models.GatewayMarkupViewModel
@{ ViewData["Title"] = "Bankaya Yönlendiriliyor..."; Layout = null; }
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bankaya Yönlendiriliyor — POS Sistemi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body class="bg-light d-flex flex-column min-vh-100 align-items-center justify-content-center">

    <div class="text-center p-5">
        <div class="mb-4">
            <span class="spinner-border text-primary" style="width:4rem;height:4rem;" role="status"></span>
        </div>
        <h3 class="fw-bold text-primary mb-2">
            <i class="bi bi-shield-lock-fill me-2"></i>@Model.Provider Güvenli Ödeme
        </h3>
        <p class="text-muted mb-1">3D Secure doğrulama sayfasına yönlendiriliyorsunuz.</p>
        <p class="text-muted small">Lütfen bekleyiniz, bu pencereyi kapatmayınız.</p>

        <div class="d-flex justify-content-center gap-3 mt-3">
            <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/3/37/Visa_Secure_Logo.png/500px-Visa_Secure_Logo.png"
                 height="32" alt="Visa Secure" />
            <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/e/e4/Mastercard_IdCheck_logo.svg/200px-Mastercard_IdCheck_logo.svg.png"
                 height="32" alt="Mastercard ID Check" />
        </div>

        <div class="mt-4">
            <button class="btn btn-outline-secondary btn-sm" id="manualBtn" style="display:none"
                    onclick="document.getElementById('frm-payment-go-to-bank').submit()">
                <i class="bi bi-arrow-right-circle me-1"></i>Otomatik yönlendirme olmadıysa tıklayın
            </button>
        </div>
    </div>

    @* Garanti Bankası'ndan dönen HTML form markup'ı *@
    @Html.Raw(Model.Markup)

    <script>
        // Sayfa yüklendiğinde formu otomatik gönder
        window.addEventListener('load', function () {
            setTimeout(function () {
                var form = document.getElementById('frm-payment-go-to-bank');
                if (form) {
                    form.submit();
                } else {
                    document.getElementById('manualBtn').style.display = 'inline-block';
                }
            }, 800);

            // 5 saniye sonra manuel buton göster
            setTimeout(function () {
                document.getElementById('manualBtn').style.display = 'inline-block';
            }, 5000);
        });
    </script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

