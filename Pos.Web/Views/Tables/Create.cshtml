@model Pos.Web.Models.CreateTableViewModel
@{ ViewData["Title"] = "Yeni Masa"; }

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Yeni Masa Ekle</h5></div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Masa No</label>
                        <input asp-for="Number" class="form-control" type="number" min="1" placeholder="Örn: 5" />
                        <span asp-validation-for="Number" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Kapasite (Kişi)</label>
                        <input asp-for="Capacity" class="form-control" type="number" min="1" max="20" />
                        <span asp-validation-for="Capacity" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Etiket <small class="text-muted">(opsiyonel)</small></label>
                        <input asp-for="Label" class="form-control" placeholder="Örn: Teras, VIP, Bahçe..." />
                    </div>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill">
                            <i class="bi bi-check-circle me-1"></i>Kaydet
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
