@model List<Pos.Web.Models.CustomerViewModel>
@{ ViewData["Title"] = "Müşteriler"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-people me-2"></i>Müşteri Listesi</h2>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-person-plus me-1"></i>Yeni Müşteri</a>
</div>

@if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>Ad Soyad</th><th>E-posta</th><th>Telefon</th><th>Adres</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>@c.FullName</td>
                    <td>@c.Email</td>
                    <td>@c.Phone</td>
                    <td>@(c.Address ?? "-")</td>
                    <td><a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-success">Detay</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>

